{
  "name": "taskflow-backend",
  "version": "1.0.0",
  "description": "TaskFlow API server",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "22.19.0",
    "pnpm": "10.28.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest ui",
    "db:migrate": "dbmate up",
    "db:seed": "psql $DATABASE_URL -f db/seed.sql"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "bcryptjs": "2.4.3",
    "dotenv": "17.4.2",
    "hono": "4.6.14",
    "pino": "9.5.0",
    "postgres": "3.4.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.1",
    "dbmate": "2.32.0",
    "pino-pretty": "13.1.3",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "4.1.4"
  }
}